{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "brainstorming",
  "plugin": [
    "opencode-anthropic-auth",
  ],
  "agent": {
    "build": {
      "color": "#E74C3C"
    },
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "mcp/sequentialthinking"
      ]
    },
    "figma-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ]
    },
    "playwright": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "environment": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "{env:PLAYWRIGHT_MCP_EXTENSION_TOKEN}"
      }
    },
    "ios-simulator": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "ios-simulator-mcp"
      ],
    },
    "sonarqube": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}"
      }
    },
    "mcp-atlassian": {
      "type": "local",
      "enabled": false,
      "command": [
        "uvx",
        "mcp-atlassian"
      ],
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USERNAME": "{env:JIRA_USERNAME}",
        "JIRA_API_TOKEN": "{env:JIRA_API_TOKEN}",
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USERNAME": "{env:CONFLUENCE_USERNAME}",
        "CONFLUENCE_API_TOKEN": "{env:CONFLUENCE_API_TOKEN}"
      }
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project-from-cwd",
        "--enable-web-dashboard",
        "false"
      ]
    },
    "fff": {
      "type": "local",
      "command": [
        "fff-mcp"
      ]
    },
    "dbhub": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "@bytebase/dbhub@latest",
        "--transport",
        "stdio",
        "--dsn",
        "{env:DATABASE_URL}"
      ]
    }
  },
}
