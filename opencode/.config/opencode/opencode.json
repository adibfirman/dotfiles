{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_speed": 3
  },
  "default_agent": "plan",
  "plugin": [
    "opencode-anthropic-auth",
  ],
  "agent": {
    "plan": {
      "color": "#3498DB",
      "allow": [
        "beads:*"
      ],
      "prompt": "When you need to ask questions for clarification, always place them at the END of your response, never in the middle of your output text."
    },
    "build": {
      "color": "#E74C3C"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "mcp/sequentialthinking"
      ]
    },
    "figma-mcp": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={env:FIGMA_API_KEY}",
        "--stdio"
      ]
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension"
      ],
      "environment": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "{env:PLAYWRIGHT_MCP_EXTENSION_TOKEN}"
      }
    },
    "ios-simulator": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "ios-simulator-mcp"
      ],
    },
    "sonarqube": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--pull=always",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "environment": {
        "SONARQUBE_TOKEN": "{env:SONARQUBE_TOKEN}",
        "SONARQUBE_ORG": "{env:SONARQUBE_ORG}"
      }
    }
  },
}
