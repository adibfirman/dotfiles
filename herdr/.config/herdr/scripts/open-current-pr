#!/bin/sh
set -eu

HERDR_BIN=${HERDR_BIN_PATH:-herdr}

notify() {
  "$HERDR_BIN" notification show "$1" --body "${2:-}" >/dev/null 2>&1 || true
}

cwd=${HERDR_ACTIVE_PANE_CWD:-$(pwd)}
if [ ! -d "$cwd" ]; then
  notify "Open PR failed" "active pane cwd is missing"
  exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
  notify "Open PR failed" "gh is not installed"
  exit 1
fi

url=$(cd "$cwd" && gh pr view --json url --jq .url 2>/dev/null || true)
if [ -z "$url" ]; then
  notify "No PR found" "No pull request for the active branch"
  exit 0
fi

open "$url"
