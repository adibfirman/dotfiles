#!/usr/bin/env python3

import argparse
import json
import os
import socket
import subprocess
import sys


def request(socket_path, request_id, method, params):
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as connection:
        connection.connect(socket_path)
        payload = {"id": request_id, "method": method, "params": params}
        connection.sendall(json.dumps(payload).encode() + b"\n")
        response = json.loads(connection.makefile().readline())

    if "error" in response:
        error = response["error"]
        raise RuntimeError(error.get("message", error.get("code", "unknown error")))
    return response["result"]


def sorted_workspaces(workspaces):
    repo_members = {}
    for workspace in workspaces:
        worktree = workspace.get("worktree")
        if worktree:
            repo_members.setdefault(worktree["repo_key"], []).append(workspace)

    grouped_repos = {
        repo_key
        for repo_key, members in repo_members.items()
        if len(members) >= 2
        and any(not member["worktree"]["is_linked_worktree"] for member in members)
    }

    blocks = {}
    for workspace in workspaces:
        worktree = workspace.get("worktree")
        if worktree and worktree["repo_key"] in grouped_repos:
            key = ("repo", worktree["repo_key"])
        else:
            key = ("workspace", workspace["workspace_id"])
        blocks.setdefault(key, []).append(workspace)

    ordered_blocks = []
    for members in blocks.values():
        parent = next(
            (
                member
                for member in members
                if member.get("worktree")
                and not member["worktree"]["is_linked_worktree"]
            ),
            members[0],
        )
        children = sorted(
            (member for member in members if member is not parent),
            key=lambda member: (member["label"].casefold(), member["workspace_id"]),
        )
        ordered_blocks.append(
            (parent["label"].casefold(), parent["workspace_id"], [parent, *children])
        )

    ordered_blocks.sort(key=lambda block: (block[0], block[1]))
    return [workspace for _, _, members in ordered_blocks for workspace in members]


def notify(title, body):
    herdr_bin = os.environ.get("HERDR_BIN_PATH", "herdr")
    subprocess.run(
        [herdr_bin, "notification", "show", title, "--body", body],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def resolve_socket_path():
    if socket_path := os.environ.get("HERDR_SOCKET_PATH"):
        return socket_path

    herdr_bin = os.environ.get("HERDR_BIN_PATH", "herdr")
    status = subprocess.run(
        [herdr_bin, "status", "server"],
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    for line in status.splitlines():
        if line.startswith("socket: "):
            return line.removeprefix("socket: ")
    raise RuntimeError("could not determine the Herdr socket path")


def main():
    parser = argparse.ArgumentParser(
        description="Sort Herdr spaces and worktrees alphabetically"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="print the sorted order without moving workspaces",
    )
    args = parser.parse_args()

    if args.dry_run:
        herdr_bin = os.environ.get("HERDR_BIN_PATH", "herdr")
        output = subprocess.run(
            [herdr_bin, "workspace", "list"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout
        workspaces = json.loads(output)["result"]["workspaces"]
        for workspace in sorted_workspaces(workspaces):
            print(f'{workspace["workspace_id"]}\t{workspace["label"]}')
        return

    socket_path = resolve_socket_path()
    result = request(socket_path, "sort:list", "workspace.list", {})
    workspaces = result["workspaces"]
    desired = sorted_workspaces(workspaces)
    current_ids = [workspace["workspace_id"] for workspace in workspaces]
    desired_ids = [workspace["workspace_id"] for workspace in desired]

    moves = 0
    for insert_index, workspace_id in enumerate(desired_ids):
        current_index = current_ids.index(workspace_id)
        if current_index == insert_index:
            continue

        request(
            socket_path,
            f"sort:move:{moves}",
            "workspace.move",
            {"workspace_id": workspace_id, "insert_index": insert_index},
        )
        current_ids.insert(insert_index, current_ids.pop(current_index))
        moves += 1

    if moves:
        notify(
            "Workspaces sorted",
            f"Alphabetized {len(desired_ids)} workspaces with {moves} moves",
        )
    else:
        notify("Workspaces already sorted", "No changes were needed")


if __name__ == "__main__":
    try:
        main()
    except Exception as error:
        notify("Workspace sort failed", str(error))
        print(f"sort-workspaces: {error}", file=sys.stderr)
        raise SystemExit(1)
