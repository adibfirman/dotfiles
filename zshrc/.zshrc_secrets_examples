# ~/.zshrc_secrets
# =================
# This file contains sensitive environment variables and API keys.
# DO NOT commit this file to version control!
#
# Instructions:
# 1. Copy this file to ~/.zshrc_secrets (or symlink it from your dotfiles)
# 2. Replace the placeholder values with your actual keys
# 3. Ensure this file has secure permissions: chmod 600 ~/.zshrc_secrets

# ============================================================================
# MCP Server Environment Variables
# ============================================================================

# Figma Developer MCP
# Get your API key from: https://www.figma.com/developers/api#authentication
# Go to: Figma Settings → Account Settings → Personal Access Tokens
export FIGMA_API_KEY="figd_your_actual_figma_api_key_here"

# Playwright MCP Extension
# Get your token from: https://github.com/microsoft/playwright-mcp/blob/main/extension/README.md
export PLAYWRIGHT_MCP_EXTENSION_TOKEN="your_actual_playwright_extension_token_here"

# SonarQube Cloud MCP
# Get your user token from: https://sonarcloud.io/account/security
# Your organization key is visible at: https://sonarcloud.io/account/organizations
export SONARQUBE_TOKEN="sqp_your_actual_sonarqube_user_token_here"
export SONARQUBE_ORG="your_sonarcloud_organization_key_here"

# Atlassian MCP (Jira & Confluence)
# Get your API tokens from: https://id.atlassian.com/manage-profile/security/api-tokens
# Your URLs will be: https://your-company.atlassian.net (Jira)
#                    https://your-company.atlassian.net/wiki (Confluence)
export JIRA_URL="https://your-company.atlassian.net"
export JIRA_USERNAME="your.email@company.com"
export JIRA_API_TOKEN="your_jira_api_token_here"
export CONFLUENCE_URL="https://your-company.atlassian.net/wiki"
export CONFLUENCE_USERNAME="your.email@company.com"
export CONFLUENCE_API_TOKEN="your_confluence_api_token_here"

# Z.AI or GLM
export Z_AI_API_KEY="your GLM or Z.AI API Key to view the Image"

# AWS Credentials (alternative to ~/.aws/credentials)
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""
export AWS_DEFAULT_REGION=""

# ============================================================================
# Add other secrets below as needed
# ============================================================================

# Example: OpenAI API Key (if you use it with other tools)
# export OPENAI_API_KEY="sk-your_openai_key_here"

# Example: GitHub Personal Access Token
# export GITHUB_TOKEN="ghp_your_github_token_here"

# Example: Database credentials for local development
# export DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
